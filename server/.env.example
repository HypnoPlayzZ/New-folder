# --- Required ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Optional: server runtime ---
PORT=8001
NODE_ENV=production

# --- Optional: bootstrap a single admin on first boot ---
# Set SEED_ADMIN=true ONCE on a fresh install. Remove after the admin can log in.
# SEED_ADMIN=true
# SEED_ADMIN_EMAIL=admin@yourdomain.com
# SEED_ADMIN_PASSWORD=replace-with-a-strong-password
# SEED_ADMIN_NAME=Admin

# --- Optional: Razorpay (online payments) ---
# Get keys from https://dashboard.razorpay.com/app/keys (Test mode for dev).
# Without these, the /api/payments/* routes return 503 and only COD works.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# RAZORPAY_WEBHOOK_SECRET=set-this-in-razorpay-dashboard-and-mirror-here

# --- Optional: SMTP (transactional emails) ---
# Gmail example: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=you@gmail.com SMTP_PASS=<App Password>
# SendGrid example: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=<SG.xxxx>
# Without these, email sends silently no-op.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Steamy Bites <orders@steamybites.shop>"

# --- Optional: Twilio (SMS OTP delivery) ---
# Without these, OTPs log to the server console in non-production only.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+15555555555
