# Production API base — used by `vite build` (the packaged iOS/Android app AND any
# hosted production build). The dev server (`npm run dev`) is NOT affected; it keeps
# using .env.local / the localhost fallback. This guarantees the native Capacitor app
# talks to the live backend instead of the default http://localhost:8001 in api.js.
VITE_API_BASE_URL=https://steamybitesbackend.onrender.com/api
